{
    "$schema": "http://json.schemastore.org/template",
    "author": "Shiny .NET",
    "classifications": [ "MAUI", "Shiny", "Prism", "ReactiveUI" ],
    "name": "Shiny MAUI Application",
    "shortName": "shinymaui",
    "description": "A project for creating a .NET MAUI /w Shiny.NET, Prism, & ReactiveUI",
    "identity": "Shiny.Templates.App",
    "sourceName": "ShinyApp",
    "preferNameDirectory": true,
    "tags": {
        "language": "C#",
        "type": "project"
    },    
    "primaryOutputs": [{
        "condition": "(HostIdentifier != \"dotnetcli\" && HostIdentifier != \"dotnetcli-preview\")",
        "path": "MauiProgram.cs"
    },{
        "condition": "(HostIdentifier != \"dotnetcli\" && HostIdentifier != \"dotnetcli-preview\")",
        "path": "Documentation.md"
    }],
    "postActions": [{
        "condition": "(HostIdentifier != \"dotnetcli\" && HostIdentifier != \"dotnetcli-preview\")",
        "description": "Open documentation file",
        "manualInstructions": [],
        "actionId": "84C0DA21-51C8-4541-9940-6CA19AF04EE6",
        "args": {
            "files": "0;1"
        },
        "continueOnError": true
    }],
    "symbols":{
        "Framework": {
            "type": "parameter",
            "description": "The target framework for the project.",
            "datatype": "choice",
            "choices": [{
                "choice": "net8.0",
                "description": "Target .NET 8.0"
            }],
            "replaces": "{DOTNET_TFM}",
            "defaultValue": "net8.0"
        },
        "markuptype": {
            "type": "parameter",
            "datatype": "choice",
            "description": "This will setup a standard XAML template, a MAUI Blazor project, or a C# powered markup using the .NET MAUI Community Toolkit",
            "displayName": "UI Markup Type",
            "choices": [{
                "choice": "XAML",
                "description": "XAML"
            },{
                "choice": "Blazor",
                "description": "Blazor"
            },{
                "choice": "CSharp",
                "description": "CSharp"
            }],
            "defaultValue": "XAML",
            "replaces": "{MARKUP_TYPE}"
        },
        "applicationId": {
            "type": "parameter",
            "description": "Set the Application Identifier",
            "datatype": "string",
            "defaultValue": "com.companyname.app",
            "isRequired": true,
            "replaces": "{APPLICATION_ID}"
        },
        "applicationIdGuid":{
            "type": "generated",
            "generator": "guid",
            "replaces": "{APPLICATION_ID_GUID}",
            "parameters": {
                "format": "D"
            }
        },
        "shinyframework": {
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "true",
            "description": "Add Shiny Framework by Allan Ritchie - Documentation https://github.com/shinyorg/framework - Lots of helpful services like navigation, zero boilerplate MVVM properties, viewmodel validation, localization, viewmodel lifecycles, dialog services, and more",
            "displayName": "Add Shiny Framework (Shiny + ReactiveUI + Prism)"
        },
        "localization":{
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "false",
            "description": "Add Localization (Microsoft.Extensions.Localization)",
            "displayName": "Add Localization (Microsoft.Extensions.Localization)"
        },
        "configuration": {
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "true",
            "description": "Add AppSettings.json (Shiny.Extensions.Configuration)",
            "displayName": "Add AppSettings.json (Shiny.Extensions.Configuration)"
        },
        "logging":{
            "displayName": "Logging Providers",
            "type": "parameter",
            "datatype": "choice",
            "allowMultipleValues": true,
            "choices": [{
                "choice": "sentry",
                "displayName": "Sentry.IO"
            },{
                "choice": "sqlite",
                "description": "SQLite Logging - (Shiny.Logging.Sqlite) - Great for logging local tests especially for background services in Shiny",
                "displayName": "SQLite (Shiny.Logging.Sqlite)"
            }],
            "defaultValue": "sentry|sqlite"
        },
        "shiny":{
            "displayName": "Shiny Modules",
            "type": "parameter",
            "datatype": "choice",
            "allowMultipleValues": true,
            "choices": [{
                "choice": "bluetoothle",
                "description": "BluetoothLE Client (Shiny.BluetoothLE)",
                "displayName": "BluetoothLE Client (Shiny.BluetoothLE)"
            },{
                "choice": "blehosting",
                "description": "BluetoothLE Hosting (Shiny.BluetoothLE.Hosting)",
                "displayName": "BluetoothLE Hosting (Shiny.BluetoothLE.Hosting)"
            },{
                "choice": "beacons",
                "description": "Beacons (Shiny.Beacons)",
                "displayName": "Beacons (Shiny.Beacons)"
            },{
                "choice": "jobs",                
                "description": "Background Jobs (Shiny.Jobs)",
                "displayName": "Background Jobs (Shiny.Jobs)"
            },{
                "choice": "gps",
                "description": "GPS/Geolocation (Shiny.Locations)",
                "displayName": "GPS/Geolocation (Shiny.Locations)"
            },{
                "choice": "geofencing",
                "description": "Geofencing (Shiny.Locations)",
                "displayName": "Geofencing (Shiny.Locations)"
            },{
                "choice": "httptransfers",
                "description": "Background HTTP Uploads & Downloads (Shiny.Net.Http)",
                "displayName": "Background HTTP Uploads & Downloads (Shiny.Net.Http)"                
            },{
                "choice": "notifications",
                "description": "Local Notifications (Shiny.Notifications)",
                "displayName": "Local Notifications (Shiny.Notifications)"                
            }]
        },
        "startup":{
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "false",
            "description": "Creates a class that executes immediately after Shiny is ready for action",
            "displayName": "Add Startup Service (Shiny.Core)"
        },
        "settings":{
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "false",
            "description": "This creates a special reactive object that binds to the platform preferences or secure storage",
            "displayName": "Add Bound Settings Class (Shiny.Core)"
        },
        "push": {
            "type": "parameter",
            "datatype": "choice",
            "defaultValue": "None",
            "description": "This will wire up all of the necessary permissions & libraries required for the selected push option.  You will still need to configure any additional API keys within the appsettings.json or MauiProgram.cs files",
            "displayName": "Shiny Push Notifications",
            "choices": [
                {
                    "choice": "None",
                    "description": "No push library is installed"
                },
                {
                    "choice": "Native",
                    "description": "Native (Shiny.Push)"
                },
                {
                    "choice": "Firebase",
                    "description": "Firebase Messaging - iOS/Android Only (Shiny.Push.FirebaseMessaging)"
                },
                {
                    "choice": "Azure Notification Hubs",
                    "description": "Azure Notifications Hubs (Shiny.Push.AzureNotificationHubs)"
                }
            ]
        },
        "authtype": {
            "type": "parameter",
            "description": "Authentication Setup - Microsoft Authentication Library (MSAL) - Documentation https://devblogs.microsoft.com/dotnet/authentication-in-dotnet-maui-apps-msal/  - MAUI WebAuthenticator: https://learn.microsoft.com/en-us/dotnet/maui/platform-integration/communication/authentication",
            "displayName": "Authentication Setup",
            "datatype": "choice",
            "choices": [{
                "choice": "None",
                "description": "None"
            },{ 
                "choice": "MAUI Web Authenticator",
                "description": "MAUI Web Authenticator"
            },{                 
                "choice": "MSAL Basic",
                "description": "Microsoft Authentication Library - Basic"
            },{
                "choice": "MSAL AzureB2C",
                "description": "Microsoft Authentication Library - AzureB2C"
            },{
                "choice": "MSAL Broker",
                "description": "Microsoft Authentication Library - Broker"
            }],
            "defaultValue": "None"
        }, 
        "msalclientid":{
            "type": "parameter",
            "dataType": "string",
            "description": "This is your Microsoft Authentication Library (MSAL) Application/Client ID setup within the Azure Portal",
            "defaultValue": "",
            "replaces":"{MSAL_CLIENT_ID}"
        },
        "authservice":{
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "false",
            "description": "Creates a sample Microsoft Authentication Library (MSAL) or Web authenticator service to work with",
            "displayName": "Create Sample Authentication Service (if MSAL or Web Authenticator is selected)"
        },
        "refit":{
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "false",
            "description": "Add Refit API Client used with sample Authentication service",
            "displayName": "Add Refit HTTP Client with Authenication Service"
        },
        "maptype": {
            "type": "parameter",
            "description": "Maps",
            "displayName": "Maps",
            "datatype": "choice",
            "choices": [{
                "choice": "None",
                "description": "None"
            },{
                "choice": "MAUI",
                "description": "MAUI"
            },{
                "choice": "Google Maps",
                "description": "For use on Android & iOS"
            }],
            "defaultValue": "None"
        },
        "mapsandroidkey":{
            "type": "parameter",
            "dataType": "string",
            "description": "This is your Google Maps API Key setup within the Google Cloud Platform. Documentation https://learn.microsoft.com/en-us/xamarin/xamarin-forms/user-interface/map/setup",
            "displayName": "Sets your Android Maps API Key (used 'Mapping Choice' is selected)",
            "defaultValue": "",
            "replaces":"{MAUI_MAPS_ANDROID_KEY}"
        },
        "mauiessentials":{
            "displayName": "MAUI Essential Setup",
            "type": "parameter",
            "datatype": "choice",
            "allowMultipleValues": true,
            "choices": [{
                "choice": "media",
                "description": "Sets all up all the necessary boilerplate for the MAUI Essentials Media Picker",
                "displayName": "Media Picker"                
            },{
                "choice": "filepicker",
                "description": "Setup all the necessary boilerplate for the MAUI Essentials File Picker",
                "displayName": "File Picker"
            },{
                "choice": "appactions",
                "description": "Sets all up all the necessary boilerplate for the MAUI App Actions",
                "displayName": "App Actions"
            }]
        },
        "deeplinks":{
            "type": "parameter",
            "description": "Sets up initial deep link support",
            "displayName": "Setup Deep Linking Support URI",
            "defaultValue": "",
            "datatype": "string",
            "replaces": "{DEEPLINK_HOST}"
        },
        "mauicontrols": {
            "displayName": "MAUI 3rd Party Controls",
            "type": "parameter",
            "datatype": "choice",
            "allowMultipleValues": true,
            "choices": [{
                "choice": "mediaelement",
                "description": "MAUI Community Toolki Media Element - Documentation https://learn.microsoft.com/en-us/dotnet/communitytoolkit/maui/",
                "displayName": "MAUI Community Toolkit Media Element"
            },{
                "choice": "virtuallist",
                "description": "MAUI Virtual List View by Jon Dick (Redth) - Documentation https://github.com/Redth/Maui.VirtualListView",
                "displayName": "MAUI Virtual List View"
            },{
                "choice": "uraniumui",
                "description": "Uranium UI by Enis Necipoglu - Documentation https://enisn-projects.io/docs/en/uranium/latest",
                "displayName": "Uranium UI"
            },{
                "choice": "sharpnadocv",
                "description": "Sharpnado CollectionView by Jean-Marie Alfonsi - Documentation https://github.com/roubachof/Sharpnado.CollectionView",
                "displayName": "Sharpnado CollectionView"
            },{
                "choice": "sharpnadotabs",
                "description": "Sharpnado Tabs by Jean-Marie Alfonsi - Documentation https://github.com/roubachof/Sharpnado.Tabs",
                "displayName": "Sharpnado Tabs"
            },{
                "choice": "ffimageloading",
                "description": "FFImageLoading MAUI - Documentation: https://github.com/microspaze/FFImageLoading.Maui",
                "displayName": "FFImageLoading MAUI"
            },{
                "choice": "skia",
                "description": "SkiaSharp - Documentation: https://github.com/mono/SkiaSharp",
                "displayName": "SkiaSharp"
            },{
                "choice": "skiaextended",
                "description": "SkiaSharp Extended (Lottie) - Documentation: https://github.com/mono/SkiaSharp.Extended",
                "displayName": "SkiaSharp Extended (Lottie)"
            }]
        },        
        "communitytoolkit":{
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "true",
            "description": "MAUI Community Toolkit - Documentation https://learn.microsoft.com/en-us/dotnet/communitytoolkit/maui/",
            "displayName": "Add MAUI Community Toolkit"
        },
        "speechrecognition": {
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "false",
            "description": "Setup Community Toolkit Speech-to-Text",
            "displayName": "Setup Community Toolkit Speech-to-Text"
        },
        "blazorcontrols":{
            "displayName": "Blazor Controls",
            "type": "parameter",
            "datatype": "choice",
            "allowMultipleValues": true,
            "choices": [{
                "choice": "mudblazor",
                "description": "MudBlazor - Documentation: https://mudblazor.com/",
                "displayName": "MudBlazor"  
            },{
                "choice": "radzen",
                "description": "Radzen.Blazor - Documentation: https://blazor.radzen.com/",
                "displayName": "Radzen"
            }]
        },
        "appservices":{
            "displayName": "Application Services",
            "type": "parameter",
            "datatype": "choice",
            "allowMultipleValues": true,
            "choices": [{
                "choice": "sqlite",
                "description": "SQLite.NET-PCL by Frank Krueger - Documentation https://github.com/praeclarum/sqlite-net",
                "displayName": "Add SQLite (SQLite.NET-PCL)"
            },{
                "choice": "barcodes",
                "description": "Wire up all of the barcode scanning services for ZXing.Net.MAUI by Jon Dick - For documentation, go to https://github.com/Redth/ZXing.Net.Maui",
                "displayName": "Barcode Scanning & Rendering (ZXing.Net.MAUI)"
            },{
                "choice": "inappbilling",
                "description": "In-App Billing by James Montemagno - Documentation https://github.com/jamesmontemagno/InAppBillingPlugin",
                "displayName": "In-App Billing (Plugin.InAppBilling)"
            },{
                "choice": "storereview",
                "description": "Store Review Plugin by James Montemagno - Documentation https://github.com/jamesmontemagno/StoreReviewPlugin",
                "displayName": "Store Review (Plugin.StoreReview)"
            },{
                "choice": "calendar",
                "description": "Calendar Store Plugin by Gerald Versluis - Documentation https://github.com/jfversluis/Plugin.Maui.CalendarStore",
                "displayName": "Calendar Store (Plugin.Maui.CalendarStore)"
            },{
                "choice": "audio",
                "description": "Audio Plugin by Gerald Versluis - Documentation https://github.com/jfversluis/Plugin.Maui.Audio",
                "displayName": "Audio (Plugin.Maui.Audio)"
            },{
                "choice": "screenrecording",
                "description": "Screen Recording Plugin by Gerald Versluis - Documentation https://github.com/jfversluis/Plugin.Maui.ScreenRecording",
                "displayName": "Screen Recording (Plugin.Maui.ScreenRecording)"
            },{
                "choice": "fingerprint",
                "description": "Fingerprint Plugin by Sven-Michael Stübe - Documentation https://github.com/smstuebe/xamarin-fingerprint",
                "displayName": "Fingerprint/Facial Recognition (Plugin.Fingerprint)"
            },{
                "choice": "embedio",
                "description": "EmbedIO Tiny Web Server - Documentation: https://unosquare.github.io/embedio/",
                "displayName": "EmbedIO Tiny Web Server"
            }]
        },
        "flipper":{
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "false",
            "description": "Add Drastic.Flipper - An amazing tool for your MAUI application by Tim Miller - Documentation: https://github.com/drasticactions/Drastic.Flipper",
            "displayName": "Add Drastic Flipper"
        }, 
        "androidauto":{
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "false",
            "description": "Add Android Auto Support"
        },
        "carplay":{
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "false",
            "description": "Add iOS CarPlay Support"
        },
        "HostIdentifier": {
            "type": "bind",
            "binding": "HostIdentifier"
        },
        "sqlite": {
            "type": "computed",
            "datatype": "bool",
            "value": "(appservices == \"sqlite\")"
        },
        "barcodes":{
            "type": "computed",
            "datatype": "bool",
            "value": "(appservices == \"barcodes\")"
        },
        "inappbilling":{
            "type": "computed",
            "datatype": "bool",
            "value": "(appservices == \"inappbilling\")"
        },
        "storereview":{
            "type": "computed",
            "datatype": "bool",
            "value": "(appservices == \"storereview\")"
        },
        "calendar":{
            "type": "computed",
            "datatype": "bool",
            "value": "(appservices == \"calendar\")"
        },
        "audio":{
            "type": "computed",
            "datatype": "bool",
            "value": "(appservices == \"audio\")"
        }, 
        "screenrecord":{
            "type": "computed",
            "datatype": "bool",
            "value": "(appservices == \"screenrecording\")"
        },
        "fingerprint":{
            "type": "computed",
            "datatype": "bool",
            "value": "(appservices == \"fingerprint\")"
        },
        "embedio": {
            "type": "computed",
            "datatype": "bool",
            "value": "(appservices == \"embedio\")"
        },        
        "mudblazor": {
            "type": "computed",
            "datatype": "bool",
            "value": "(blazorcontrols == \"mudblazor\")" 
        },
        "radzen": {
            "type": "computed",
            "datatype": "bool",
            "value": "(blazorcontrols == \"radzen\")"
        },        
        "essentialsmedia":{
            "type": "computed",
            "datatype": "bool",
            "value": "(mauiessentials == \"media\")"
        },
        "essentialsfilepicker":{
            "type": "computed",
            "datatype": "bool",
            "value": "(mauiessentials == \"filepicker\")"
        },
        "appactions":{
            "type": "computed",
            "datatype": "bool",
            "value": "(mauiessentials == \"appactions\")"
        },  
        "mediaelement":{
            "type": "computed",
            "datatype": "bool",
            "value": "(mauicontrols == \"mediaelement\")"
        },
        "virtuallist":{
            "type": "computed",
            "datatype": "bool",
            "value": "(mauicontrols == \"virtuallist\")"
        },
        "uraniumui":{
            "type": "computed",
            "datatype": "bool",
            "value": "(mauicontrols == \"uraniumui\")"
        },
        "sharpnadocv":{
            "type": "computed",
            "datatype": "bool",
            "value": "(mauicontrols == \"sharpnadocv\")"
        },
        "sharpnadotabs":{
            "type": "computed",
            "datatype": "bool",
            "value": "(mauicontrols == \"sharpnadotabs\")"
        },
        "skia":{
            "type": "computed",
            "datatype": "bool",
            "value": "(mauicontrols == \"skia\")"
        },
        "skiaextended":{
            "type": "computed",
            "datatype": "bool",
            "value": "(mauicontrols == \"skiaextended\")"
        },
        "ffimageloading":{
            "type": "parameter",
            "datatype": "bool",
            "defaultValue": "false",
            "description": "Add FFImageLoading MAUI - Documentation: https://github.com/microspaze/FFImageLoading.Maui",
            "displayName": "Add FFImageLoading MAUI" 
        },              
        "usewebauthenticator":{
            "type": "computed",
            "datatype": "bool",
            "value": "(authtype == \"MAUI Web Authenticator\")"
        },
        "usemsal":{
            "type": "computed",
            "datatype": "bool",
            "value": "(authtype == \"MSAL Basic\" || authtype == \"MSAL AzureB2C\" || authtype == \"MSAL Broker\")"
        },
        "sentry": {
            "type": "computed",
            "dataType": "bool",
            "description": "(logging == \"sentry\")"
        },        
        "sqlitelogging": {
            "type": "computed",
            "dataType": "bool",
            "description": "(logging == \"sqlite\")"
        },
        "bluetoothle": {
            "type": "computed",
            "datatype": "bool",
            "value": "(shiny == \"bluetoothle\")"
        },
        "blehosting": {
            "type": "computed",
            "datatype": "bool",
            "value": "(shiny == \"blehosting\")"
        },
        "beacons": {
            "type": "computed",
            "datatype": "bool",
            "value": "(shiny == \"beacons\")"  
        },
        "jobs": {
            "type": "computed",
            "datatype": "bool",
            "value": "(shiny == \"jobs\")"
        },
        "gps":{
            "type": "computed",
            "datatype": "bool",
            "value": "(shiny == \"gps\")"
        },
        "geofencing":{
            "type": "computed",
            "datatype": "bool",
            "value": "(shiny == \"geofencing\")"
        },
        "httptransfers": {
            "type": "computed",
            "datatype": "bool",
            "value": "(shiny == \"httptransfers\")"
        },
        "notifications": {
            "type": "computed",
            "datatype": "bool",
            "value": "(shiny == \"notifications\")"
        },        
        "usemaps":{
            "type": "computed",
            "datatype": "bool",
            "value": "(maptype != \"None\")"
        },
        "usemauimaps":{
            "type": "computed",
            "datatype": "bool",
            "value": "(maptype == \"MAUI\")"
        },        
        "usegooglemaps":{
            "type": "computed",
            "datatype": "bool",
            "value": "(maptype == \"Google Maps\")"
        },
        "usemsalbasic":{
            "type": "computed",
            "datatype": "bool",
            "value": "(authtype == \"MSAL Basic\")"
        },
        "usemsalb2c":{
            "type": "computed",
            "datatype": "bool",
            "value": "(authtype == \"MSAL AzureB2C\")"
        },
        "usemsalbroker":{
            "type": "computed",
            "datatype": "bool",
            "value": "(authtype == \"MSAL Broker\")"
        },
        "usepushnative":{
            "type": "computed",
            "datatype": "bool",
            "value": "(push == \"Native\")"
        },
        "usepushfirebase":{
            "type": "computed",
            "datatype": "bool",
            "value": "(push == \"Firebase\")"
        },
        "usepushanh":{
            "type": "computed",
            "datatype": "bool",
            "value": "(push == \"Azure Notification Hubs\")"
        },
        "usepush":{
            "type": "computed",
            "datatype": "bool",
            "value": "(push != \"None\")"
        },
        "useconfig":{
            "type": "computed",
            "datatype": "bool",
            "value": "(configuration || push != \"None\" || appcenter != \"\" || authtype != \"None\")"
        },
        "useappcenter":{
            "type": "computed",
            "datatype": "bool",
            "value": "(appcenter != \"\")"
        },
        "usedeeplinks":{
            "type": "computed",
            "datatype": "bool",
            "value": "(deeplinks != \"\")"
        },        
        "usemaccatalyst":{
            "type": "computed",
            "datatype": "bool",
            "value": "(usepushfirebase == false && usemsal == false)"
        },
        "usexaml":{
            "type": "computed",
            "datatype": "bool",
            "value": "(markuptype == \"XAML\")"
        },
        "useblazor":{
            "type": "computed",
            "datatype": "bool",
            "value": "(markuptype == \"Blazor\")"
        },
        "usecsharpmarkup":{
            "type": "computed",
            "datatype": "bool",
            "value": "(markuptype == \"CSharp\")"
        },        
        "usehttp":{
            "type": "computed",
            "datatype": "bool",
            "value": "(authservice && refit)"
        }
    },
    "sources": [{
        "source": "./",
        "target": "./",
        "copyOnly": [
            "**/*.svg",
            "**/*.ttf",
            "**/*.txt"
        ],
        "modifiers": [
        {
            "condition": "(useconfig == false)",
            "exclude": [
                "appsettings.json",
                "appsettings.android.json",
                "appsettings.apple.json",
                "appsettings.ios.json",
                "appsettings.maccatalyst.json"
            ]
        },
        {
            "condition": "(startup == false)",
            "exclude": "AppStartup.cs"
        },
        {
            "condition": "(settings == false)",
            "exclude": "AppSettings.cs"
        },
        {
            "condition": "(localization == false)",
