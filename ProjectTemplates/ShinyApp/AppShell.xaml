<?xml version="1.0" encoding="utf-8"?>
<shiny:ShinyShell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:local="clr-namespace:ShinyApp"
                  xmlns:shiny="clr-namespace:Shiny;assembly=Shiny.Maui.Shell"
                  Shell.FlyoutBehavior="Disabled"
                  x:Class="ShinyApp.AppShell"
                  x:DataType="local:AppShell">
    <ShellContent Title="Main Page"
                  ContentTemplate="{DataTemplate local:MainPage}"
                  Route="MainPage" />
</shiny:ShinyShell>